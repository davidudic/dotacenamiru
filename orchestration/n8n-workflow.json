      ],
      "parameters": {
        "jsCode": "const v = $input.first().json;\nreturn [{ json: { ok: true, action: 'post', contentId: v.id, contentUrl: 'https://www.youtube.com/watch?v=' + v.id, publishedAt: v.snippet && v.snippet.publishedAt, raw: { id: v.id, status: v.status } } }];"
      }
    },
