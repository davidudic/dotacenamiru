    {
      "id": "a0dca913-44ea-4695-a435-9e2630f9c1b3",
      "name": "Prep",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        96
      ],
      "parameters": {
        "jsCode": "const b = $input.first().json.body;\nif (b.action === 'metrics') {\n  const res = await this.helpers.httpRequest({\n    method: 'GET',\n    url: 'https://www.googleapis.com/youtube/v3/videos',\n    qs: { part: 'statistics,snippet', id: b.contentId },\n    headers: { Authorization: 'Bearer ' + b.accessToken },\n    json: true,\n  });\n  return [{ json: { action: 'metrics', ok: true, raw: res } }];\n}\nconst bytes = Buffer.from(b.mediaBase64, 'base64');\nconst init = await this.helpers.httpRequest({\n  method: 'POST',\n  url: 'https://www.googleapis.com/upload/youtube/v3/videos?uploadType=resumable&part=snippet,status',\n  headers: {\n    Authorization: 'Bearer ' + b.accessToken,\n    'Content-Type': 'application/json; charset=UTF-8',\n    'X-Upload-Content-Type': b.mediaContentType || 'video/mp4',\n    'X-Upload-Content-Length': String(bytes.length),\n  },\n  body: { snippet: { title: b.title, description: b.description || '', categoryId: '22' }, status: { privacyStatus: b.privacy || 'private', selfDeclaredMadeForKids: false } },\n  json: true,\n  returnFullResponse: true,\n});\nconst location = init.headers.location || init.headers.Location;\nconst binaryData = await this.helpers.prepareBinaryData(bytes, 'upload.mp4', b.mediaContentType || 'video/mp4');\nreturn [{ json: { action: 'post', location, contentType: b.mediaContentType || 'video/mp4' }, binary: { data: binaryData } }];"
      }
    },
    {
      "id": "69da2c15-f687-4e5e-b97d-02a2c795aca8",
      "name": "Is Post",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        448,
        96
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "loose",
            "version": 2
          },
          "conditions": [
            {
              "leftValue": "={{ $json.action }}",
              "rightValue": "post",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "1823d0b7-5dba-48da-b99f-a1dda599bc78",
